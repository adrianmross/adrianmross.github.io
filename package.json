{
  "name": "adrianmross.github.io",
  "version": "2.0.0",
  "private": true,
  "description": "Adrian M. Ross portfolio, built with Next.js and statically exported for GitHub Pages.",
  "author": "Adrian Ross",
  "type": "module",
  "engines": {
    "node": "22 || 24"
  },
  "scripts": {
    "dev": "next dev",
    "dev:portless": "portless-worktree-dev run",
    "dev:watch": "portless-worktree-dev start",
    "dev:watch:restart": "portless-worktree-dev restart",
    "dev:watch:status": "portless-worktree-dev status",
    "dev:watch:stop": "portless-worktree-dev stop",
    "dev:watch:logs": "portless-worktree-dev logs",
    "url:portless": "portless-worktree-dev url",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "portless": {
    "name": "adrianmross-github-io"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.5.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "next": "^16.0.10",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sugar-high": "^0.6.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "portless": "0.13.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "packageManager": "pnpm@11.1.2"
}
